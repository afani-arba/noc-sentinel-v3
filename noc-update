#!/bin/bash
# ╔══════════════════════════════════════════════════════════════════════════╗
# ║   NOC Sentinel v3 — One-Command Update Script                           ║
# ║                                                                          ║
# ║   INSTALL (sekali saja di server):                                       ║
# ║     sudo bash /opt/noc-sentinel-v3/install-update.sh                    ║
# ║                                                                          ║
# ║   CARA PAKAI:  sudo noc-update                                          ║
# ╚══════════════════════════════════════════════════════════════════════════╝
set -e

APP_DIR="/opt/noc-sentinel-v3"
SERVICE="ARBAMonitoring"
VENV="$APP_DIR/backend/venv"
[ -d "$APP_DIR/backend/.venv" ] && VENV="$APP_DIR/backend/.venv"

G='\033[0;32m'; Y='\033[1;33m'; R='\033[0;31m'; B='\033[1;34m'; N='\033[0m'; BOLD='\033[1m'
ok()   { echo -e "  ${G}✔ $*${N}"; }
warn() { echo -e "  ${Y}⚠ $*${N}"; }
err()  { echo -e "\n${R}${BOLD}✗ ERROR: $*${N}\n"; exit 1; }
step() { echo -e "\n${BOLD}${B}▶ $*${N}"; }

# ── Root check ───────────────────────────────────────────────────────────────
[[ $EUID -ne 0 ]] && err "Jalankan sebagai root: sudo noc-update"
[[ ! -d "$APP_DIR/.git" ]] && err "Direktori $APP_DIR tidak ditemukan. Sudah di-install?"

echo -e "\n${BOLD}${B}╔════════════════════════════════════════════╗${N}"
echo -e "${BOLD}${B}║       NOC Sentinel v3 — Update             ║${N}"
echo -e "${BOLD}${B}╚════════════════════════════════════════════╝${N}"
echo -e "  Waktu : $(date '+%Y-%m-%d %H:%M:%S')"
echo -e "  Versi : $(git -C $APP_DIR rev-parse --short HEAD 2>/dev/null || echo '?')"
echo ""

# ══════════════════════════════════════════════════════════════════════════════
# STEP 1 — STOP SERVICE DULU (sebelum pull/build)
# Ini kritis: memastikan port 8000 benar-benar bebas SEBELUM kita mulai build
# ══════════════════════════════════════════════════════════════════════════════
step "[1/5] Stop Backend (bebaskan port 8000)..."

systemctl stop "$SERVICE" 2>/dev/null || true

# Tunggu service inactive (max 20 detik)
i=0
while systemctl is-active --quiet "$SERVICE" 2>/dev/null && [[ $i -lt 20 ]]; do
    sleep 1; i=$((i+1))
done

# Bunuh paksa semua proses yang masih memegang port 8000
set +e
PIDS=$(lsof -ti:8000 2>/dev/null)
if [[ -n "$PIDS" ]]; then
    echo "  Membunuh proses di port 8000: $PIDS"
    kill -9 $PIDS 2>/dev/null
fi
fuser -k 8000/tcp 2>/dev/null
set -e

# Tunggu port benar-benar bebas (max 15 detik)
echo -n "  Menunggu port 8000 bebas"
p=0
while lsof -ti:8000 &>/dev/null && [[ $p -lt 15 ]]; do
    echo -n "."; sleep 1; p=$((p+1))
done
echo ""

if lsof -ti:8000 &>/dev/null; then
    warn "Port 8000 masih busy! Force kill terakhir..."
    fuser -k -KILL 8000/tcp 2>/dev/null || true
    sleep 2
fi

ok "Backend stopped — port 8000 bebas"

# ── 2. Git Pull ──────────────────────────────────────────────────────────────
step "[2/5] Git Pull dari GitHub..."
cd "$APP_DIR"
BEFORE=$(git rev-parse --short HEAD)
git pull origin main 2>/dev/null || git pull origin master 2>/dev/null || warn "Git pull gagal — melanjutkan dengan kode lokal"
AFTER=$(git rev-parse --short HEAD)

if [[ "$BEFORE" == "$AFTER" ]]; then
    warn "Tidak ada update baru (commit: $AFTER)"
else
    ok "Updated: $BEFORE → $AFTER"
    echo -e "  Perubahan: $(git log -1 --format='%s')"
fi

# ── 3. Python deps ───────────────────────────────────────────────────────────
step "[3/5] Update Python packages..."
"$VENV/bin/pip" install --upgrade pip -q
"$VENV/bin/pip" install -r "$APP_DIR/backend/requirements.txt" -q

# Force install pysnmp-lextudio jika belum ada
# PENTING: Uninstall pysnmp lama dulu (konflik dengan pysnmp-lextudio)
if "$VENV/bin/python" -c "from pysnmp.hlapi import SnmpEngine" 2>/dev/null; then
    ok "pysnmp (lextudio) tersedia di venv ✓"
else
    warn "pysnmp belum tersedia — install pysnmp-lextudio..."
    # Hapus semua versi pysnmp yang konflik
    "$VENV/bin/pip" uninstall pysnmp pysnmp-lextudio -y -q 2>/dev/null || true
    # Install versi yang kompatibel
    "$VENV/bin/pip" install 'pysnmp-lextudio>=1.1.0,<2.0.0' -q \
        && ok "pysnmp-lextudio terinstall" \
        || warn "pysnmp-lextudio gagal install (fitur SNMP nonaktif)"
fi
ok "Python packages OK"

# ── 4. Build Frontend ────────────────────────────────────────────────────────
step "[4/5] Build Frontend..."
cd "$APP_DIR/frontend"
npm install --legacy-peer-deps --prefer-offline -q 2>/dev/null || npm install --legacy-peer-deps -q
npm run build
[[ -f "build/index.html" ]] && ok "Frontend build OK → build/" || err "Build frontend gagal"

# ── 5. Start Backend ─────────────────────────────────────────────────────────
step "[5/5] Start Backend..."

# Pastikan SYSLOG_PORT di .env pakai port non-privileged (5140)
ENV_FILE="$APP_DIR/backend/.env"
if [[ -f "$ENV_FILE" ]]; then
    # Jika .env masih set SYSLOG_PORT=514, otomatis ganti ke 5140
    if grep -q "^SYSLOG_PORT=514$" "$ENV_FILE" 2>/dev/null; then
        sed -i 's/^SYSLOG_PORT=514$/SYSLOG_PORT=5140/' "$ENV_FILE"
        ok ".env: SYSLOG_PORT diperbaiki 514 → 5140 (non-privileged)"
    fi
fi

systemctl daemon-reload
systemctl start "$SERVICE"
sleep 5

if systemctl is-active --quiet "$SERVICE"; then
    ok "Backend '$SERVICE': RUNNING ✔"
else
    echo -e "${R}✗ Backend gagal start! Log:${N}"
    journalctl -u "$SERVICE" -n 30 --no-pager
    exit 1
fi

# Reload nginx
systemctl reload nginx 2>/dev/null && ok "Nginx di-reload" || true

# ── Health check ─────────────────────────────────────────────────────────────
sleep 2
if curl -sf http://localhost:8000/api/health 2>/dev/null | grep -q "ok"; then
    ok "API health check: OK ✔"
else
    warn "API belum respond — cek: journalctl -u $SERVICE -f"
fi

# ── Selesai ──────────────────────────────────────────────────────────────────
echo ""
echo -e "${G}${BOLD}╔════════════════════════════════════════════╗${N}"
echo -e "${G}${BOLD}║   ✅  UPDATE SELESAI!                       ║${N}"
echo -e "${G}${BOLD}╚════════════════════════════════════════════╝${N}"
echo ""
echo -e "  Commit  : $(git -C $APP_DIR log -1 --format='%h — %s')"
echo -e "  Backend : $(systemctl is-active $SERVICE)"
echo -e "  Waktu   : $(date '+%Y-%m-%d %H:%M:%S')"
echo ""
echo -e "  ${Y}➡ Hard refresh browser: Ctrl+Shift+R${N}"
echo ""
